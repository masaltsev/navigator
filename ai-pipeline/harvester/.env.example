# LLM (DeepSeek via LiteLLM)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek/deepseek-chat

# Navigator Core Internal API (Sprint 2+)
CORE_API_URL=http://backend.test
CORE_API_TOKEN=Bearer your-token-here

# Dadata (Sprint 2+)
# Default: suggest API (free, 10K/day). Set DADATA_USE_CLEAN=true for paid clean API.
DADATA_API_KEY=
DADATA_SECRET_KEY=
DADATA_USE_CLEAN=false

# Redis (Celery, Sprint 3+)
REDIS_URL=redis://localhost:6379/0

# Crawl4AI
CRAWL4AI_HEADLESS=true
CRAWL4AI_USER_AGENT=NavigatorHarvester/1.0 (+https://navigator.vnuki.fund)

# Optional: Firecrawl Cloud fallback
# FIRECRAWL_API_KEY=fc-xxxxx
